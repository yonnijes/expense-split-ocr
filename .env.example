# --- CONFIGURACIÓN DE APP ---
NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- GOOGLE GEMINI (IA) ---
# Consíguela en https://aistudio.google.com/
GEMINI_API_KEY=tu_clave_aqui
GEMINI_MODEL=gemini-1.5-flash

# --- BASE DE DATOS (POSTGRESQL / DOKPLOY) ---
DATABASE_URL="postgresql://user:password@postgres:5432/expense_split"

# --- SUPABASE STORAGE (IMÁGENES) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_BUCKET=ticket-images

# --- WEB (SSR) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL_INTERNAL=http://api:8000

# --- SEGURIDAD (JWT) ---
JWT_SECRET=una_cadena_muy_larga_y_aleatoria_12345
JWT_EXPIRES_IN=7d

# --- OPTIMIZACIÓN DE IMÁGENES ---
MAX_FILE_SIZE=5242880
