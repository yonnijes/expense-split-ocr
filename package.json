{
  "name": "expense-split-ocr",
  "version": "0.1.0",
  "private": true,
  "description": "MVP monorepo para OCR de tickets + split de gastos",
  "scripts": {
    "dev:web": "nx serve web-portal",
    "build:web": "nx build web-portal",
    "start:web": "nx start web-portal",
    "dev:api": "nx serve api",
    "build:api": "nx build api",
    "dev:web:legacy": "cd apps/web-portal && node ../../node_modules/next/dist/bin/next dev",
    "build:web:legacy": "cd apps/web-portal && node ../../node_modules/next/dist/bin/next build",
    "start:web:legacy": "cd apps/web-portal && node ../../node_modules/next/dist/bin/next start -p 3000",
    "dev:api:legacy": "node ./node_modules/tsx/dist/cli.mjs watch --tsconfig tsconfig.json apps/api/src/main.ts",
    "build:api:legacy": "tsc -p apps/api/tsconfig.app.json && tsc-alias -p apps/api/tsconfig.app.json"
  },
  "dependencies": {
    "@google/genai": "^0.14.1",
    "@hookform/resolvers": "^3.9.1",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/schedule": "^5.0.1",
    "@prisma/client": "^6.0.0",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.0",
    "next": "^15.1.0",
    "prisma": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "zod": "^4.1.11",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "nx": "^20.0.0",
    "@nx/next": "^20.0.0",
    "@nx/nest": "^20.0.0"
  }
}
